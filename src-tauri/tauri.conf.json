{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AstarScan",
  "version": "0.1.0",
  "identifier": "com.astarworks.astarscan",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "devUrl": "http://localhost:3005",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "apps/web/.output/public"
  },
  "app": {
    "title": "AstarScan",
    "windows": [
      {
        "title": "AstarScan — Edge Document Scanner",
        "width": 400,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
