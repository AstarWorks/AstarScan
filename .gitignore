# Build outputs
# Note: `dist` (no trailing slash) also matches symlinks — Nuxt auto-creates
# apps/web/dist as a symlink to .output/public, which must not be committed.
dist
build
.nuxt
.output
*.tsbuildinfo

# Bun — bun.lock is committed (CI needs it to detect Bun as package manager)

