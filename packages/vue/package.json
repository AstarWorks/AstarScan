{
  "name": "@astarworks/scan-vue",
  "version": "0.0.0",
  "description": "Vue 3 adapter for @astarworks/scan-core — reactive composables and components for edge document scanning. Framework-agnostic, does NOT depend on Nuxt.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AstarWorks/AstarScan.git",
    "directory": "packages/vue"
  },
  "keywords": [
    "vue",
    "vue3",
    "composables",
    "document-scanner",
    "pdf",
    "pwa"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build --config vite.lib.config.ts",
    "build:watch": "vite build --config vite.lib.config.ts --watch",
    "typecheck": "vue-tsc --noEmit",
    "test": "echo 'TODO: vitest' && exit 0",
    "lint": "echo 'TODO: eslint' && exit 0",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@astarworks/scan-core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.6.3",
    "vite": "^7.1.12",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
