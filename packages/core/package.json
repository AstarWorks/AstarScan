{
  "name": "@astarworks/scan-core",
  "version": "0.0.0",
  "description": "Pure TypeScript core for AstarScan — edge document scanner pipeline, framework-agnostic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AstarWorks/AstarScan.git",
    "directory": "packages/core"
  },
  "keywords": [
    "document-scanner",
    "pdf",
    "edge-detection",
    "opencv",
    "pwa",
    "offline-first"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build --config vite.lib.config.ts",
    "build:watch": "vite build --config vite.lib.config.ts --watch",
    "typecheck": "tsc --noEmit",
    "test": "echo 'TODO: vitest' && exit 0",
    "lint": "echo 'TODO: eslint' && exit 0",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^7.1.12",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
