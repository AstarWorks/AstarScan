{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  // Nuxt's generated tsconfig includes nuxt.config.ts in its `include` list.
  // Plain `tsc --noEmit` (our typecheck fallback) doesn't resolve
  // Nuxt's extended `defineNuxtConfig` type correctly — it fails on
  // the `nitro` key with TS2353. Since `nuxt generate` validates the
  // config at build time, we can safely exclude it from tsc.
  "exclude": ["./nuxt.config.ts", "nuxt.config.ts"],
  // Disable vue-tsc plugins to work around a vue-router 4.6 / @vue/language-core
  // 3.x compat bug where the `vue-router/volar/sfc-route-blocks` subpath is
  // not exported. We don't use <route> blocks in SFCs so this plugin is
  // irrelevant; explicitly disabling it avoids the load failure.
  "vueCompilerOptions": {
    "plugins": []
  }
}
